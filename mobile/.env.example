# Copy to .env and fill in values.

# --- Backend ---
# Defaults to the live production backend so the app works on any wifi /
# cellular without needing the dev machine running. Override to your LAN IP
# (e.g. http://192.168.1.19:8000) if you want to hit a local backend.
EXPO_PUBLIC_API_BASE_URL=https://api.expense-tracker.blueelephants.org

# --- Google OAuth (platform-specific clients) ---
# Create three OAuth 2.0 Client IDs in console.cloud.google.com -> Credentials.
# Each one is FREE - no Apple Developer Program membership needed.
#
# Application type: iOS
#   Bundle ID:      org.blueelephants.familyexpensetracker
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# Application type: Android
#   Package name:   org.blueelephants.familyexpensetracker
#   SHA-1:          run `cd mobile/android && ./gradlew signingReport` after
#                   `npx expo prebuild --platform android` and paste here
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Application type: Web application (same one the web frontend uses)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
