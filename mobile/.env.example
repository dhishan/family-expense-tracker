# Copy to .env and fill in values
# API base URL - points to the FastAPI backend
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000

# Google OAuth Client ID for native apps
# Create at console.cloud.google.com -> APIs & Services -> Credentials -> OAuth 2.0 Client ID
# Select "iOS" or "Android" as application type
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id-here
